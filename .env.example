# Pathly Website — Environment Variables
# Copy to .env.local and fill in values

# Tally.so Waitlist Form (EU Server, DSGVO-konform)
NEXT_PUBLIC_TALLY_FORM_ID=

# Pathly App URL (for CTA links)
NEXT_PUBLIC_APP_URL=https://app.path-ly.eu

# Feature-Flag: Set to 'true' to show Pricing section (paid mode)
# NOTE: Changing this requires a Vercel Redeploy (NEXT_PUBLIC_* is build-time)
NEXT_PUBLIC_SHOW_PRICING=false
